# DB_USER=postgres
# DB_PASSWORD=your_password
# DB_HOST=localhost
# DB_PORT=5432

# CORS (frontend origin)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

