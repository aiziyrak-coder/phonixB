# Django
SECRET_KEY=your-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,*

# Database (SQLite - default)
USE_SQLITE=True
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

